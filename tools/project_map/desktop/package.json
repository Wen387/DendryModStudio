{
  "name": "dendry-mod-studio-desktop",
  "version": "0.98.5",
  "private": true,
  "author": {
    "name": "Awen",
    "email": "127130120+Wen387@users.noreply.github.com",
    "url": "https://github.com/Wen387"
  },
  "homepage": "https://github.com/Wen387/DendryModStudio",
  "description": "Desktop shell for Dendry Mod Studio.",
  "main": "main.js",
  "dendryModStudio": {
    "updateManifestUrl": "https://raw.githubusercontent.com/Wen387/DendryModStudio/main/tools/project_map/desktop/update_manifest.json"
  },
  "scripts": {
    "start": "electron .",
    "fetch:python": "node scripts/fetch_bundled_python.js",
    "generate:icons": "node scripts/generate_windows_icon.js",
    "package:dir": "node scripts/package_dir.js",
    "package:portable": "node scripts/package_portable.js",
    "package:deb": "node scripts/package_deb.js",
    "dist:linux": "npm run fetch:python && electron-builder --linux AppImage deb --x64",
    "dist:win": "npm run fetch:python && electron-builder --win nsis --x64",
    "dist:win:fast-install": "npm run fetch:python && electron-builder --config build/electron-builder.win-fast-install.cjs --win nsis --x64",
    "dist:win:deps-in-asar": "npm run fetch:python && electron-builder --config build/electron-builder.win-deps-in-asar.cjs --win nsis --x64",
    "dist:win:no-python": "electron-builder --config build/electron-builder.win-no-python.cjs --win nsis --x64",
    "dist:win:no-node-modules": "electron-builder --config build/electron-builder.win-no-node-modules.cjs --win nsis --x64",
    "dist:win:shell-only": "electron-builder --config build/electron-builder.win-shell-only.cjs --win nsis --x64",
    "analyze:payload": "node scripts/analyze_payload.js",
    "measure:win-install": "powershell -ExecutionPolicy Bypass -File scripts/measure_windows_install.ps1",
    "smoke": "node ../check_desktop_shell.js",
    "doctor": "node scripts/doctor.js"
  },
  "build": {
    "appId": "studio.dendry.mod",
    "productName": "Dendry Mod Studio",
    "artifactName": "DendryModStudio-${os}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "dist-builder"
    },
    "files": [
      "main.js",
      "preload.js",
      "studio_core.js",
      "template_catalog.js",
      "template_catalog.json",
      "publish/**",
      "dendry_cli_runner.js",
      "runtime_preview.js",
      "template_adopt.js",
      "source_slice_read.js",
      "runtime_lens.js",
      "runtime_session_cleanup.js",
      "runtime_preview_debug_bridge.js",
      "object_playtest_host.js",
      "update_notice.js",
      "update_manifest.json",
      "package.json",
      "scripts/**",
      "assets/**",
      {
        "from": "../viewer",
        "to": "project_map/viewer",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.map"
        ]
      },
      {
        "from": "../authoring",
        "to": "project_map/authoring",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.map"
        ]
      },
      {
        "from": "../schema",
        "to": "project_map/schema",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.map"
        ]
      },
      {
        "from": "..",
        "to": "project_map",
        "filter": [
          "parse_dry_project.js",
          "object_playtest_engine_model.js"
        ]
      },
      {
        "from": "../../../node_modules",
        "to": "node_modules",
        "filter": [
          "**/*",
          "!**/.git/**",
          "!**/.github/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/coverage/**",
          "!**/doc/**",
          "!**/docs/**",
          "!**/example/**",
          "!**/examples/**",
          "!**/test/**",
          "!**/tests/**",
          "!**/*.map",
          "!**/*.md",
          "!**/*.markdown",
          "!**/.jshint*",
          "!**/.npmignore",
          "!**/package-lock.json"
        ]
      },
      {
        "from": "../../../node_modules/acorn-node/node_modules/acorn",
        "to": "node_modules/acorn-node/node_modules/acorn",
        "filter": [
          "**/*",
          "!**/.git/**",
          "!**/.github/**",
          "!**/test/**",
          "!**/tests/**",
          "!**/*.map",
          "!**/*.md",
          "!**/*.markdown",
          "!**/package-lock.json"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "../profiles",
        "to": "app/project_map/profiles"
      },
      {
        "from": "../templates",
        "to": "app/project_map/templates"
      },
      {
        "from": "../build_project_map.py",
        "to": "app/project_map/build_project_map.py"
      },
      {
        "from": "../indexer",
        "to": "app/project_map/indexer"
      },
      {
        "from": "runtime",
        "to": "app/runtime"
      }
    ],
    "linux": {
      "artifactName": "DendryModStudio-linux-x64.${ext}",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "maintainer": "Awen <127130120+Wen387@users.noreply.github.com>",
      "icon": "assets/dendry-mod-studio.svg"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    },
    "win": {
      "artifactName": "DendryModStudio-win-x64.${ext}",
      "icon": "assets/dendry-mod-studio.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/dendry-mod-studio.ico",
      "uninstallerIcon": "assets/dendry-mod-studio.ico",
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  }
}
