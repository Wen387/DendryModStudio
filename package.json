{
  "name": "dendry-mod-studio",
  "version": "0.98.0",
  "private": true,
  "description": "Desktop and browser tooling for Dendry Mod Studio.",
  "scripts": {
    "check:public": "node tools/project_map/check_public_export.js",
    "check:surface": "node tools/project_map/check_studio_surface.js",
    "check:localization": "node tools/project_map/check_localization_surface.js",
    "check:dynamic": "node tools/project_map/check_dynamic_mod_audit.js",
    "check:dynamicrepo-events": "node tools/project_map/check_dynamicrepo_event_authoring_parity.js --require-fixture --with-project-index",
    "check:dynamicrepo-event-samples": "node tools/project_map/check_dynamicrepo_event_editor_samples.js --require-fixture",
    "check:dynamicrepo-event-install": "node tools/project_map/check_dynamicrepo_event_install_acceptance.js --require-fixture --with-html-build --with-runtime-proof",
    "check:runtime-surface": "node tools/project_map/check_runtime_surface_model.js",
    "check:runtime-snapshot": "node tools/project_map/check_runtime_snapshot_model.js",
    "check:runtime-dom-map": "node tools/project_map/check_runtime_dom_map_model.js",
    "check:runtime-visual-surface": "node tools/project_map/check_runtime_visual_surface_model.js",
    "check:runtime-visual-asset-draft": "node tools/project_map/check_runtime_visual_asset_draft_model.js",
    "check:types": "tsc -p tools/project_map/tsconfig.json && node tools/project_map/check_ts_ready_contracts.js",
    "check:interactions": "node tools/project_map/check_canvas_interaction_contracts.js",
    "check:complexity": "node tools/project_map/check_source_complexity.js --enforce-budget",
    "check:ci": "node tools/project_map/run_checks.js",
    "check:system-ui-semantic": "node tools/project_map/check_system_ui_semantic_task_model.js"
  },
  "dependencies": {
    "dendrynexus": "https://github.com/aucchen/dendrynexus/archive/aa4287ed2c03940c52b190c0a8c102b795ac1c79.tar.gz",
    "parliament-svg": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  }
}
