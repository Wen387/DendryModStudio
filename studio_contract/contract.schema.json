{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/islands-sunrise/studio-contract.schema.json",
  "title": "IslandSunrise Studio Compatibility Contract",
  "description": "Schema for the islands-sunrise Studio compatibility contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractVersion",
    "contractId",
    "projectName",
    "profileId",
    "profileChain",
    "studioProfilePath",
    "parserFixtureRoot",
    "requiredInvariants",
    "stableRouters",
    "semanticSystems",
    "variableFamilies",
    "protectedBoundaries",
    "protectedPathPrefixes",
    "installBoundary",
    "parserFixtureExpectations"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "contractVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "contractId": {"type": "string", "minLength": 1},
    "projectName": {"type": "string", "minLength": 1},
    "profileId": {"type": "string", "minLength": 1},
    "profileChain": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "studioProfilePath": {"type": "string", "minLength": 1},
    "parserFixtureRoot": {"type": "string", "minLength": 1},
    "requiredInvariants": {
      "type": "array",
      "items": {"type": "string", "pattern": "^INV-[A-Z0-9-]+$"},
      "minItems": 1
    },
    "stableRouters": {
      "type": "array",
      "items": {"type": "string", "pattern": "^source/scenes/.+\\.scene\\.dry$"},
      "minItems": 1
    },
    "semanticSystems": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "variableFamilies": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "protectedBoundaries": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "protectedPathPrefixes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "installBoundary": {
      "type": "object",
      "additionalProperties": {
        "enum": [
          "safe_apply",
          "guarded_apply",
          "advanced_apply",
          "manual_review",
          "ide_escape_hatch",
          "refused"
        ]
      }
    },
    "parserFixtureExpectations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileIds", "minSummary", "requiredScenes", "requiredVariables"],
      "properties": {
        "profileIds": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        },
        "minSummary": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "requiredScenes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        },
        "requiredVariables": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        }
      }
    }
  }
}
