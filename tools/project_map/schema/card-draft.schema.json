{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dendry-mod-studio.local/schemas/card-draft.v0.1.schema.json",
  "title": "CardDraft v0.1",
  "type": "object",
  "required": ["schemaVersion", "kind", "id", "title", "cardKind", "options"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "kind": { "const": "card" },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "cardKind": { "enum": ["action_card", "advisor_like"] },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "viewIf": { "type": "string" },
    "priority": { "type": "integer" },
    "frequency": { "type": "integer" },
    "maxVisits": { "type": "integer" },
    "heading": { "type": "string" },
    "subtitle": { "type": "string" },
    "introParagraphs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/option" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "option": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "chooseIf": { "type": "string" },
        "unavailableText": { "type": "string" },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effect" }
        },
        "narrativeParagraphs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gotoAfter": { "type": "string" }
      },
      "additionalProperties": true
    },
    "effect": {
      "type": "object",
      "required": ["variable", "op", "value"],
      "properties": {
        "variable": { "type": "string" },
        "op": { "enum": ["=", "+=", "-="] },
        "value": {}
      },
      "additionalProperties": true
    }
  }
}
